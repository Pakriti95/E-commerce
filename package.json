{
  "name": "shopnest-full-stack",
  "version": "1.0.0",
  "description": "",
  "keywords": [
    "Akriti",
    "microservice"
  ],
  "license": "ISC",
  "author": "Akriti",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "install": "cd backend && npm install && cd ../frontend && npm install",
    "start": "node backend/server.js",
    "dev:server": "cd backend && npm run dev",
    "dev:client": "cd frontend && npm start",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build" : "cd frontend && npm run build",
    "start:backend": "npm --prefix backend run dev",
    "start:frontend": "npm --prefix frontend run dev",
    "seed": "npm --prefix backend run seed"
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
